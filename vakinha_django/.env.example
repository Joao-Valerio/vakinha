# ============================================================
# Django
# ============================================================
SECRET_KEY=django-insecure-replace-with-a-long-random-string-in-production
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=yourdomain.railway.app,yourdomain.com
SITE_URL=https://yourdomain.railway.app

# ============================================================
# Database — Neon (https://console.neon.tech) — NÃO exige Railway
# Use a string "Pooled" (porta 6432) no seu PC; `?sslmode=require` costuma vir na URL
# USE_LOCAL_SQLITE=1 abaixo força SQLite e ignora esta linha
# ============================================================
USE_LOCAL_SQLITE=0
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# ============================================================
# Redis — Railway
# Add a Redis service in Railway → copy the REDIS_URL
# ============================================================
REDIS_URL=redis://default:password@monorail.proxy.rlwy.net:PORT

# ============================================================
# MercadoPago
# Get from: https://www.mercadopago.com.br/developers/panel/credentials
# ============================================================
MERCADOPAGO_ACCESS_TOKEN=APP_USR-your-access-token-here
MERCADOPAGO_PUBLIC_KEY=APP_USR-your-public-key-here
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret

# ============================================================
# Email (Gmail SMTP example)
# ============================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=seu@email.com
EMAIL_HOST_PASSWORD=sua-senha-de-app
DEFAULT_FROM_EMAIL=Vakinha IA <noreply@vakinha.ai>

# ============================================================
# WhatsApp — Evolution API
# ============================================================
EVOLUTION_API_URL=https://api.evolution-api.com/v2
EVOLUTION_INSTANCE=NomeDaSuaInstancia
EVOLUTION_TOKEN=your-evolution-api-token-here

# ============================================================
# AI Agent
# ============================================================
GEMINI_API_KEY=AIzaSy-your-gemini-key-here
# Modelo (agno 2.x / google-genai). Plano free: prefira modelos "flash" e evite burst
GEMINI_MODEL=gemini-2.0-flash
# Reduz histórico no prompt (menos tokens / menos 429)
GEMINI_NUM_HISTORY_RUNS=2
# Retry com backoff quando a API retornar 429 (Too Many Requests)
GEMINI_MAX_RETRIES=6
GEMINI_RETRY_BASE_SECONDS=2
GROQ_API_KEY=gsk_your-groq-key-here

# Secret token for the WhatsApp webhook URL
# Configure in Evolution API as: https://yoursite.com/ai/webhook/<AI_WEBHOOK_TOKEN>/
AI_WEBHOOK_TOKEN=generate-a-long-random-token-here

# ============================================================
# Optional: Sentry error monitoring
# ============================================================
# SENTRY_DSN=https://xxx@sentry.io/project-id
